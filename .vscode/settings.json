{
  "files.exclude": {
    ".git": true,
    "node_modules": true,
    "*.vsix": true,
    ".publish": true
  },
  "cSpell.enabled": true,
  "cSpell.ignorePaths": [
    "package-lock.json",
    "node_modules",
    ".git",
    ".vscode",
    ".gitignore",
    ".editorconfig"
  ],
  "cSpell.enabledFileTypes": {
    "javascript": true,
    "json": true,
    "markdown": true,
    "plaintext": true,
    "text": true
  },
  "cSpell.dictionaries": ["en_us", "filetypes", "node", "npm"]
}
